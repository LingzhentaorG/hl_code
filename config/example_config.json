{
  "_comment": "DEM 生成器示例配置文件 - 单一官方 DEM 产线",
  "input": {
    "file_path": "../data/基准.ply",
    "_description_file_path": "输入的 ASCII PLY 点云文件路径"
  },
  "crs": {
    "epsg_code": 4326,
    "allow_unknown_crs": false,
    "_description_epsg_code": "输出 GeoTIFF 写入的 EPSG 编码",
    "_description_allow_unknown_crs": "是否允许未知 CRS 继续处理"
  },
  "preprocess": {
    "sample_spacing_count": 512,
    "max_extreme_sample": 5000,
    "_description": "基础预处理与极端异常值采样参数"
  },
  "outlier": {
    "knn": 16,
    "stddev_multiplier": 1.5,
    "use_robust_stat": false,
    "_description": "SOR 离群点过滤参数"
  },
  "ground": {
    "seed_grid_size": 0.0,
    "knn": 8,
    "search_radius": 0.0,
    "max_height_diff": 1.0,
    "max_slope_deg": 20.0,
    "max_iterations": 6,
    "min_ground_neighbors": 3,
    "reference_mode": "local_plane",
    "reference_fallback_mode": "inverse_distance_squared",
    "distance_weight_power": 2.0,
    "min_neighbor_completeness": 0.5,
    "_description": "地面点提取与支撑精炼参数"
  },
  "dem": {
    "cell_size": 8.0,
    "idw_k": 12,
    "idw_min_points": 3,
    "idw_max_distance": 0.0,
    "idw_allow_fallback": true,
    "idw_power": 2.0,
    "nodata": -9999.0,
    "boundary_outline_cells": 1.0,
    "_description": "官方 DEM 使用 ArcGIS 风格 KNN IDW；idw_max_distance<=0 时按输出范围对角线"
  },
  "tile": {
    "mode": "auto",
    "tile_size_cells": 1000,
    "tile_buffer": 0.0,
    "memory_limit_mb": 512,
    "_description": "大点云分块处理参数"
  },
  "output": {
    "directory": "../output",
    "overwrite": true,
    "write_png": true,
    "timestamp_subdir": true,
    "write_debug_pointclouds": false,
    "_description": "默认输出 surface/mask/log；pointcloud 仅在调试开关开启时写出"
  }
}
